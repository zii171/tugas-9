{
  "info": {
    "name": "Tugas 9 - Todo API (NestJS + MySQL + TypeORM)",
    "description": "Koleksi pengujian untuk API Todo. Sudah termasuk skenario valid dan invalid.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "todoId", "value": "1" }
  ],
  "item": [
    {
      "name": "1. Create Todo - Valid",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Belajar NestJS\",\n  \"description\": \"Mengerjakan tugas 9 API Todo\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2026-07-05\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/todos", "host": ["{{baseUrl}}"], "path": ["todos"] }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "pm.test('Response punya id', function () {",
              "  pm.expect(pm.response.json()).to.have.property('id');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2. Create Todo - Invalid (title kosong)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"\",\n  \"priority\": \"high\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/todos", "host": ["{{baseUrl}}"], "path": ["todos"] }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Create Todo - Invalid (priority salah)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Contoh todo\",\n  \"priority\": \"urgent\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/todos", "host": ["{{baseUrl}}"], "path": ["todos"] }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 Bad Request', function () {",
