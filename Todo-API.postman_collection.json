    {
      "name": "4. Create Todo - Invalid (field tidak dikenal)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Contoh todo\",\n  \"randomField\": \"halo\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/todos", "host": ["{{baseUrl}}"], "path": ["todos"] }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 - forbidNonWhitelisted', function () {",
              "  pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. Get All Todos",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/todos", "host": ["{{baseUrl}}"], "path": ["todos"] }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response berupa array', function () {",
              "  pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Get All Todos - Filter completed=true",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/todos?completed=true",
          "host": ["{{baseUrl}}"],
          "path": ["todos"],
          "query": [{ "key": "completed", "value": "true" }]
        }
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
